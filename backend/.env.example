# Kite credentials
KITE_API_KEY=your_api_key
KITE_API_SECRET=your_api_secret
# Option 1 (recommended): paste full redirected callback URL after login
# Example: https://your.redirect.url/?request_token=...&action=login&status=success
KITE_REDIRECTED_URL=
# If you use local callback handling, set Kite app redirect URL to:
# http://127.0.0.1:8000/kite/callback

# Option 2: if you already extracted it manually
# KITE_REQUEST_TOKEN=your_request_token

# Optional fallback if you already generated it:
# KITE_ACCESS_TOKEN=your_access_token
# Enforce token-only mode (recommended once token is set):
KITE_ACCESS_TOKEN_ONLY=true

# Runtime
DRY_RUN=true
LOG_LEVEL=INFO
LOG_JSON=false
# LOG_FILE=logs/strategy.log

DATABASE_URL=

# Frontend URL for OAuth redirect
FRONTEND_BASE_URL=http://localhost:3000